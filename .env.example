# =============================================================================
# AutoFood Environment Variables
# =============================================================================
# Copy this file to `.env` (or `.env.local`) and fill in real values.
# NEVER commit real secrets to git. Gitleaks scans run on every push/PR.
#
# Variable convention:
#   NEXT_PUBLIC_* — exposed to browser (safe for non-secret config only)
#   All others    — server-only (never sent to client)
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL via Neon)
# -----------------------------------------------------------------------------
# Runtime: use the POOLED connection string (Neon host contains "-pooler").
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler:5432/DATABASE?sslmode=require"
# Migrations/introspection: use the DIRECT (non-pooled) connection string.
# Prisma uses this for `migrate`/`db push`. REQUIRED whenever the schema declares
# directUrl — Prisma does not auto-fall back to DATABASE_URL. Local tooling
# (scripts/prisma-generate.mjs) defaults it to DATABASE_URL, but set it explicitly
# in production/CI to get the real direct (non-pooled) host.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# NextAuth.js v5 — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-strong-random-string"
# NEXTAUTH_SECRET="optional-legacy-secret"

# Custom JWT signing for internal APIs — generate with: openssl rand -base64 32
JWT_SECRET="replace-with-strong-random-string"

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Scheduled Jobs (cron)
# -----------------------------------------------------------------------------
# Secrets used to authenticate internal cron job requests
CRON_SECRET="replace-with-strong-random-string"
CRON_SECRET_TOKEN="replace-with-strong-random-string"

# -----------------------------------------------------------------------------
# AI Providers
# -----------------------------------------------------------------------------
# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# Tambo AI (client-side) — https://tambo.co
NEXT_PUBLIC_TAMBO_API_KEY=""
# Optional: enable suggestions UI (may 403 depending on your Tambo project)
NEXT_PUBLIC_TAMBO_ENABLE_SUGGESTIONS=false

# -----------------------------------------------------------------------------
# Routing
# -----------------------------------------------------------------------------
# OpenRouteService — https://openrouteservice.org/dev/#/api-docs
OPENROUTESERVICE_API_KEY=""

# -----------------------------------------------------------------------------
# Firebase
# -----------------------------------------------------------------------------
# Public client config (safe for browser)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_DATABASE_URL=""

# Server-only: full service account JSON (paste the entire JSON as a string)
# NEVER commit the JSON file — use this env var instead
FIREBASE_SERVICE_ACCOUNT_KEY=""

# -----------------------------------------------------------------------------
# Multi-tenant / Subdomain
# -----------------------------------------------------------------------------
# Root domain for subdomain links (e.g. autofood.uz)
NEXT_PUBLIC_ROOT_DOMAIN="localhost:3000"
# Optional: subdomain-first | project-first (empty = auto; *.vercel.app => project-first)
NEXT_PUBLIC_SUBDOMAIN_URL_STYLE=""

# -----------------------------------------------------------------------------
# SMS / OTP Provider
# -----------------------------------------------------------------------------
# Which provider to use: console | textbelt | infobip | custom
SMS_PROVIDER="console"

# Textbelt — https://textbelt.com/
TEXTBELT_API_KEY=""

# Infobip — https://portal.infobip.com/
INFOBIP_BASE_URL=""
INFOBIP_API_KEY=""
INFOBIP_SENDER="InfoSMS"

# Custom SMS provider (generic webhook)
SMS_API_URL=""
SMS_API_TOKEN=""
